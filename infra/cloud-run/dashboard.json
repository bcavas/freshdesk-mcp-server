{
    "displayName": "Freshdesk MCP Server Dashbaord",
    "gridLayout": {
        "columns": "2",
        "widgets": [
            {
                "title": "Request Count",
                "xyChart": {
                    "dataSets": [
                        {
                            "timeSeriesQuery": {
                                "timeSeriesFilter": {
                                    "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"freshdesk-mcp-server\"",
                                    "aggregation": {
                                        "alignmentPeriod": "60s",
                                        "perSeriesAligner": "ALIGN_RATE"
                                    }
                                }
                            }
                        }
                    ]
                }
            },
            {
                "title": "Request Latency",
                "xyChart": {
                    "dataSets": [
                        {
                            "timeSeriesQuery": {
                                "timeSeriesFilter": {
                                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"freshdesk-mcp-server\"",
                                    "aggregation": {
                                        "alignmentPeriod": "60s",
                                        "crossSeriesReducer": "REDUCE_PERCENTILE_99",
                                        "perSeriesAligner": "ALIGN_DELTA"
                                    }
                                }
                            }
                        }
                    ]
                }
            }
        ]
    }
}