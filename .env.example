# Freshdesk MCP Server — Environment Variables
# Copy this file to .env for local development
# In production, all secrets are injected via Google Secret Manager

# ── Required ──────────────────────────────────────────────────────────
# Your Freshdesk API key (found in Profile Settings → API Key)
FRESHDESK_API_KEY=your_api_key_here

# Your Freshdesk subdomain (e.g., "yourcompany" for yourcompany.freshdesk.com)
FRESHDESK_DOMAIN=your_subdomain_here

# ── Runtime ───────────────────────────────────────────────────────────
# HTTP port — Cloud Run injects this automatically; do not set in production
PORT=8080

# Environment name: local | staging | production
NODE_ENV=local

# Log verbosity: debug | info | warn | error
LOG_LEVEL=debug

# MCP transport protocol
MCP_TRANSPORT=streamable-http

# ── Security ───────────────────────────────────────────────────────────
# Pre-shared API key for the /mcp endpoint. When set, all MCP clients must
# include this value as the x-api-key request header. /health is always exempt.
# Leave unset for local development. In production, store in Secret Manager.
# Generate with: openssl rand -hex 32
MCP_API_KEY=
